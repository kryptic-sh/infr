#version 460
// Tiled dp4a (mmq) GEMM for stacked IQ4_XS experts (unsloth-dynamic Qwen3.6-MoE UD quants mix
// IQ4_XS into most gate/up expert banks): C[m,n] = A[m,k]·W[ids]ᵀ via hardware int8 dot-product.
// IQ4_XS is a CODEBOOK format like IQ4_NL (see native_gemm_mmq_iq4_nl.comp's doc for the
// kvalues_iq4nl table) but with a Q4_K-shaped superblock: w = d·(ls−32)·kvalues_iq4nl[q4], ls a
// 6-bit sub-block scale (4 low bits in `scales_l`, 2 high bits in `scales_h`). `ls−32` is SIGNED
// (unlike Q4_K's separately-stored min, there is no additive min term at all — the table lookup
// is already the correct signed dp4a operand, same as IQ4_NL) so this binds NO `sact`. BLK=32 —
// ONE of IQ4_XS's 8 sub-blocks per 256-elem superblock — matches the activation's quant block
// exactly (one dact per block, one `ls` per block), mirroring native_gemm_mmq_q4k's superblock
// addressing (`sub = (gelem/32)&7`, `bd = (gelem/256)*136`) with the min/`sact` machinery removed
// and the nibble→int8 step replaced by nibble→table-lookup (native_gemm_mmq_iq4_nl.comp's
// `kv_iq4nl`). Block (136 bytes): [half d][uint16 scales_h][uint8 scales_l[4]][uint8 qs[128]] —
// ground-truthed against infr-gguf's dequant.rs IQ4_XS CPU reference and native_decode.glsl's
// FMT_IQ4XS `dq`/`dqblk`. Requires n%64, k%32.
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int32 : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_integer_dot_product : require
#extension GL_EXT_control_flow_attributes : require

#ifndef BM_TILE
#define BM_TILE 64u
#endif
const uint BM = BM_TILE; // row tile — 64 default, EXPERT_GRID batched-MoE callers may
                         // override smaller (e.g. 32) to fit small per-expert row counts

const uint BN = 64u;
const uint BLK = 32u;       // one IQ4_XS sub-block == the activation's 32-block, exactly
const uint WPB = BLK / 4u;  // 8 packed-int8 u32 words per 32-block
const uint TM = 4u;
const uint TN = 4u;
const uint THREADS = (BM / TM) * (BN / TN); // 256
const uint SP = WPB + 1u;

layout(local_size_x = THREADS, local_size_y = 1, local_size_z = 1) in;
layout(push_constant) uniform PC { uint m; uint n; uint k; uint w_base; } pc;
layout(binding = 0) readonly buffer QA { uint qa[]; };          // [m, k/4] packed int8 activations
layout(binding = 1) readonly buffer DA { float16_t dact[]; };   // [m, k/32]
layout(binding = 2) readonly buffer WB { uint nw[]; };          // stacked IQ4_XS weight bytes
#ifdef PAGED
// PAGED (implies EXPERT_GRID): `nw` is a GpuPager arena of uniform slots; see
// native_gemm_mmq_q2_k.comp's PAGED doc (word base not slot index, pc.w_base = layer_base, pc.m
// unused, rb() chokepoint).
layout(binding = 3) readonly buffer LUT { uint lut[]; };
layout(binding = 4) readonly buffer CNT { uint counts[]; };
layout(binding = 5) readonly buffer OFF { uint offsets[]; };
layout(binding = 6) writeonly buffer CB { float c[]; };         // [n_pairs, n] packed
#elif defined(EXPERT_GRID)
// Batched-MoE all-experts-in-one-dispatch: gl_WorkGroupID.y = expert id; the packed activation
// rows for expert e live at [offsets[e], offsets[e]+counts[e]) (bucket layout). pc.m is repurposed
// as the per-expert weight stride (elements). Row tiles past the segment exit immediately; row
// stores are clipped to the segment (rows are packed — no per-expert padding to stomp). The two
// extra readonly inputs sit before `c` so the recorder's inputs-first/outputs-last order holds.
layout(binding = 3) readonly buffer CNT { uint counts[]; };
layout(binding = 4) readonly buffer OFF { uint offsets[]; };
layout(binding = 5) writeonly buffer CB { float c[]; };         // [n_pairs, n] packed
#else
layout(binding = 3) writeonly buffer CB { float c[]; };         // [m, n]
#endif

shared uint As[BM * SP];
shared uint Bs[BN * SP];
shared float Bdl[BN];

#ifdef PAGED
uint nw_base = 0u; // this expert's arena WORD base (set once in main from the LUT)
uint rb(uint byte) { return (nw[nw_base + (byte >> 2)] >> ((byte & 3u) * 8u)) & 0xFFu; }
#else
uint rb(uint byte) { return (nw[byte >> 2] >> ((byte & 3u) * 8u)) & 0xFFu; }
#endif
uint ru16(uint byte) { return rb(byte) | (rb(byte + 1u) << 8u); }
float f16tof32(uint bits) { return unpackHalf2x16(bits & 0xffffu).x; }

// kvalues_iq4nl, byte-packed 4-per-u32 — see native_gemm_mmq_iq4_nl.comp's doc (kept local: these
// mmq shaders are self-contained, no #include).
const uint KV_IQ4NL_W[4] = uint[](0xBFAD9881u, 0xF6EADDCFu, 0x26190D01u, 0x71594535u);
int kv_iq4nl(uint idx) {
    return bitfieldExtract(int(KV_IQ4NL_W[idx >> 2u]), int((idx & 3u) << 3u), 8);
}

void main() {
    uint nblk = pc.k / BLK;
    uint kw = pc.k / 4u;
    uint tilesN = pc.n / BN;
#ifdef EXPERT_GRID
    uint ex = gl_WorkGroupID.y;
    uint cnt = counts[ex];
    if ((gl_WorkGroupID.x / tilesN) * BM >= cnt) { return; }
    uint wgRow = offsets[ex] + (gl_WorkGroupID.x / tilesN) * BM;
    uint rowEnd = offsets[ex] + cnt;
#ifdef PAGED
    // Resolved AFTER the count early-exit: a bucket with count 0 was never routed, so its LUT
    // entry may be stale/absent — no workgroup that would read it gets here.
    nw_base = lut[pc.w_base + ex];
    uint wbase = 0u;
#else
    uint wbase = pc.w_base + ex * pc.m;
#endif
#else
    uint wgRow = (gl_WorkGroupID.x / tilesN) * BM;
    uint wbase = pc.w_base;
#endif
    uint wgCol = (gl_WorkGroupID.x % tilesN) * BN;
    uint li = gl_LocalInvocationIndex;
    uint tr = li / (BN / TN);
    uint tc = li % (BN / TN);

    float acc[TM][TN];
    [[unroll]] for (uint i = 0u; i < TM; i++)
        [[unroll]] for (uint j = 0u; j < TN; j++) acc[i][j] = 0.0;

#ifdef EXPERT_GRID
    // Dead-row mask — see native_gemm_mmq_q4k.comp for the full rationale. A tile is only skipped
    // WHOLESALE above (first row past the segment); inside a PARTIAL tile the rows past `rowEnd`
    // still ran the full dp4a loop and had their results thrown away by the clipped store. On a
    // 256-expert × top-8 pool (Qwen3.6-35B-A3B UD mixes IQ4_XS into the gate/up banks: ~16 routed
    // rows/expert at pp512) even the BM=32 `_xp32` tile the recorder picks is HALF dead rows.
    //
    // Thread→row is `tr = li / (BN/TN)`, so `live` is uniform across each 8-row-per-wave stripe —
    // fully-dead waves retire the loop body instead of diverging. Staging and BOTH barriers stay
    // UNCONDITIONAL: every invocation must reach every barrier, and dead threads still stage the
    // As/Bs/Bdl the live ones read.
    bool live = (wgRow + tr * TM) < rowEnd;
#else
    const bool live = true;
#endif

    for (uint blk = 0u; blk < nblk; blk++) {
        // stage activations: BM rows × WPB packed words (rows ≥ m read garbage, output ignored)
        for (uint idx = li; idx < BM * WPB; idx += THREADS) {
            uint r = idx / WPB;
            uint p = idx % WPB;
            As[r * SP + p] = qa[(wgRow + r) * kw + blk * WPB + p];
        }
        // per-col scale d·(ls−32) for this sub-block: `sub` (0..7) is this 32-block's index within
        // its 256-elem superblock, derived from the COLUMN's own element offset (mirrors
        // native_gemm_mmq_q4k's `sub = (gelem/32)&7`).
        for (uint cc = li; cc < BN; cc += THREADS) {
            uint gelem = wbase + (wgCol + cc) * pc.k + blk * BLK;
            uint bd = (gelem / 256u) * 136u;
            uint sub = (gelem / 32u) & 7u;
            float d = f16tof32(ru16(bd));
            uint scales_h = ru16(bd + 2u);
            uint lo = (rb(bd + 4u + (sub >> 1u)) >> (4u * (sub & 1u))) & 0xFu;
            uint hi = (scales_h >> (2u * sub)) & 3u;
            uint ls = lo | (hi << 4u);
            Bdl[cc] = d * float(int(ls) - 32);
        }
        // stage weights: BN cols × WPB words — nibble → signed codebook lookup → packed int8, NO
        // further centering (the table is already the correct signed dp4a operand).
        for (uint idx = li; idx < BN * WPB; idx += THREADS) {
            uint cc = idx / WPB;
            uint p = idx % WPB;
            uint gelem = wbase + (wgCol + cc) * pc.k + blk * BLK;
            uint bd = (gelem / 256u) * 136u;
            uint sub = (gelem / 32u) & 7u;
            uint qbase = bd + 8u + 16u * sub;
            uint packed = 0u;
            [[unroll]] for (uint b = 0u; b < 4u; b++) {
                uint within = p * 4u + b;
                uint idx4 = (within < 16u)
                    ? (rb(qbase + within) & 0xFu)
                    : (rb(qbase + within - 16u) >> 4u);
                packed |= (uint(kv_iq4nl(idx4)) & 0xFFu) << (b * 8u);
            }
            Bs[cc * SP + p] = packed;
        }
        barrier();

        if (live) {
        int qsum[TM][TN];
        [[unroll]] for (uint i = 0u; i < TM; i++)
            [[unroll]] for (uint j = 0u; j < TN; j++) qsum[i][j] = 0;
        [[unroll]] for (uint p = 0u; p < WPB; p++) {
            int av[TM];
            int bv[TN];
            [[unroll]] for (uint i = 0u; i < TM; i++) av[i] = int(As[(tr * TM + i) * SP + p]);
            [[unroll]] for (uint j = 0u; j < TN; j++) bv[j] = int(Bs[(tc * TN + j) * SP + p]);
            [[unroll]] for (uint i = 0u; i < TM; i++)
                [[unroll]] for (uint j = 0u; j < TN; j++)
                    qsum[i][j] = dotPacked4x8AccSatEXT(av[i], bv[j], qsum[i][j]);
        }

        float dval[TM];
        [[unroll]] for (uint i = 0u; i < TM; i++)
            dval[i] = float(dact[(wgRow + tr * TM + i) * nblk + blk]);
        [[unroll]] for (uint j = 0u; j < TN; j++) {
            float dl = Bdl[tc * TN + j];
            [[unroll]] for (uint i = 0u; i < TM; i++) {
                acc[i][j] += dval[i] * dl * float(qsum[i][j]);
            }
        }
        }
        // Placed AFTER the shared-scale reads above (Bdl/Bmm), not after the qsum loop: every
        // shared read of this iteration (As/Bs in qsum AND the per-col scales here) must complete
        // before any thread loops around and restages — a barrier between qsum and this block let
        // a fast thread overwrite Bdl/Bmm while a slow one was still reading them (data race,
        // exposed by the BN=128 wide tile's fuller occupancy; nondeterministic expert GEMM output).
        barrier();
    }

    [[unroll]] for (uint i = 0u; i < TM; i++) {
        uint rr = wgRow + tr * TM + i;
#ifdef EXPERT_GRID
        if (rr >= rowEnd) { continue; }
#endif
        [[unroll]] for (uint j = 0u; j < TN; j++) {
            c[rr * pc.n + (wgCol + tc * TN + j)] = acc[i][j];
        }
    }
}
