#version 460
// RMSNorm: y[i] = x[i] * inversesqrt(mean(x²) + eps) * w[i], one workgroup per row.
// -DGATE build (`rmsnorm_gate`): fuses in the qwen35 DeltaNet z-gate multiply
// -DADD build (`rmsnorm_add`): fuses in an in-place add to dst: dst[i] += norm_result[i]
// Requires requiredSubgroupSize=32 (wave32 → 8 subgroups).
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PC { uint rows; uint dim; float eps; } pc;
layout(binding = 0) readonly buffer XB { float x[]; };
layout(binding = 1) readonly buffer WB { float w[]; };
#ifdef GATE
layout(binding = 2) readonly buffer ZB { float z[]; };
layout(binding = 3) buffer YB { float y[]; };
#elif defined(ADD)
layout(binding = 2) buffer DB { float dst[]; };
#else
layout(binding = 2) buffer YB { float y[]; };
#endif

shared float part[8];

void main() {
    uint r = gl_WorkGroupID.x;
    uint t = gl_LocalInvocationIndex;
    uint base = r * pc.dim;

    float ss = 0.0;
    for (uint i = t; i < pc.dim; i += 256u) { float v = x[base + i]; ss += v * v; }
    ss = subgroupAdd(ss);
    if (subgroupElect()) { part[gl_SubgroupID] = ss; }
    barrier();

    float tot = 0.0;
    uint nsg = gl_NumSubgroups;
    for (uint s = 0u; s < nsg; s++) { tot += part[s]; }
    float scale = inversesqrt(tot / float(pc.dim) + pc.eps);

#ifdef GATE
    for (uint i = t; i < pc.dim; i += 256u) {
        float zv = z[base + i];
        float gate = zv / (1.0 + exp(-zv));
        y[base + i] = x[base + i] * scale * w[i] * gate;
    }
#elif defined(ADD)
    for (uint i = t; i < pc.dim; i += 256u) { dst[base + i] += x[base + i] * scale * w[i]; }
#else
    for (uint i = t; i < pc.dim; i += 256u) { y[base + i] = x[base + i] * scale * w[i]; }
#endif
}
