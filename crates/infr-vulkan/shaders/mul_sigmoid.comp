#version 460
// Elementwise sigmoid gate: y[i] = a[i] * sigmoid(b[i]). Qwen3-Next's per-head attention output gate
// (attn · sigmoid(gate)). `a` and `b` may alias `y` for in-place use.
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(push_constant) uniform PC { uint n; } pc;
layout(binding = 0) readonly buffer AB { float a[]; };
layout(binding = 1) readonly buffer BB { float b[]; };
layout(binding = 2) writeonly buffer YB { float y[]; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.n) {
        return;
    }
    y[i] = a[i] / (1.0 + exp(-b[i]));
}
