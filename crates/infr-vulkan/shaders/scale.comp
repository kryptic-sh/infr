#version 460
// In-place elementwise scalar multiply: y[i] *= scale. Used for gemma4's per-layer output scale.
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(push_constant) uniform PC { uint n; float scale; } pc;
layout(binding = 0) buffer YB { float y[]; };
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < pc.n) { y[i] *= pc.scale; }
}
