#version 460
// Gated-GLU with SEPARATE gate/up buffers: y[i] = act(gate[i]) * up[i]. One thread/element.
// Default act = SiLU (SwiGLU). -DGELU = GELU tanh-approx (GeGLU) — gemma4's per-layer-embd gate.
// up_off/up_stride/row_width: strided read from `up` buffer (E2B per-layer embedding).
// gate_stride/gate_row_width: strided read from `gate` buffer (qwen35 interleaved q+g).
// 0 = tightly packed (stride == row_width).
layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PC { uint n; uint up_off; uint up_stride; uint row_width; uint gate_stride; uint gate_row_width; } pc;
layout(binding = 0) readonly buffer GB { float gate[]; };
layout(binding = 1) readonly buffer UB { float up[]; };
layout(binding = 2) buffer YB { float y[]; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.n) { return; }
    float g;
    if (pc.gate_stride == 0u) {
        g = gate[i];
    } else {
        uint r = i / pc.gate_row_width;
        uint c = i % pc.gate_row_width;
        g = gate[r * pc.gate_stride + c];
    }
#ifdef GELU
    float a = 0.5 * g * (1.0 + tanh(0.7978845608028654 * (g + 0.044715 * g * g * g)));
#else
    float a = g / (1.0 + exp(-g));
#endif
    uint up_idx;
    if (pc.up_stride == 0u) {
        up_idx = pc.up_off + i;
    } else {
        uint r = i / pc.row_width;
        uint c = i % pc.row_width;
        up_idx = pc.up_off + r * pc.up_stride + c;
    }
    y[i] = a * up[up_idx];
}
